{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/orenlab/ckdn/blob/main/src/ckdn/schemas/ckdn.aggregate.v1.schema.json",
  "title": "ckdn.aggregate/1",
  "description": "Routing document emitted on stdout for an alias run. Lists only members that actually ran; each member also has its own ckdn.digest/2 on disk.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "alias", "status", "rc", "members"],
  "properties": {
    "schema": {"const": "ckdn.aggregate/1"},
    "alias": {"type": "string", "minLength": 1},
    "status": {"enum": ["pass", "fail"]},
    "rc": {"type": "integer"},
    "members": {"type": "array", "items": {"$ref": "#/$defs/member"}}
  },
  "$defs": {
    "member": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check", "status", "rc"],
      "properties": {
        "check": {"type": "string", "minLength": 1},
        "status": {"enum": ["pass", "fail", "error", "parse_mismatch"]},
        "rc": {"type": "integer"},
        "run_dir": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "pass"}}},
          "then": {"not": {"required": ["run_dir"]}},
          "else": {"required": ["run_dir"]}
        }
      ]
    }
  }
}
